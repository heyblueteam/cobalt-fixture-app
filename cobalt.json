{
  "version": "1.0",
  "name": "cobalt-fixture-app",
  "images": {
    "default": {
      "dockerfile": "Dockerfile",
      "context": "."
    }
  },
  "services": {
    "web": {
      "type": "container",
      "image": "default",
      "port": 3000,
      "volumes": [
        { "name": "data", "destinationPath": "/data" }
      ]
    },
    "worker": {
      "type": "container",
      "image": "default",
      "command": "/worker.sh"
    },
    "tick-counter": {
      "type": "cron",
      "image": "default",
      "schedule": "* * * * *",
      "command": "echo \"tick at $(date -u +%H:%M:%S)\" >> /data/cron.log",
      "volumes": [
        { "name": "data", "destinationPath": "/data" }
      ]
    }
  }
}
