{
  "version": "1.0",
  "name": "cobalt-fixture-app",
  "images": {
    "default": {
      "dockerfile": "Dockerfile",
      "context": "."
    }
  },
  "services": {
    "web": {
      "type": "container",
      "image": "default",
      "port": 3000,
      "volumes": [
        { "name": "data", "destinationPath": "/data" },
        { "name": "sentinels", "destinationPath": "/usr/share/nginx/html/sentinels" }
      ]
    },
    "worker": {
      "type": "container",
      "image": "default",
      "command": "/worker.sh"
    },
    "hook:deploy:start:before": {
      "type": "command",
      "image": "default",
      "command": "set -eu; mkdir -p /sentinels; if grep -q host.docker.internal /etc/hosts; then echo HOOK-BEFORE-EXTRARUNPARAMS-OK; printf '%s' OK > /sentinels/before-extra-run-params; else echo HOOK-BEFORE-EXTRARUNPARAMS-MISSING; printf '%s' MISSING > /sentinels/before-extra-run-params; fi; echo \"HOOK-BEFORE-SENTINEL marker=${HOOK_MARKER:-unset}\"; printf '%s' \"${HOOK_MARKER:-unset}\" > /sentinels/before",
      "extraRunParams": "--add-host host.docker.internal:host-gateway",
      "volumes": [
        { "name": "sentinels", "destinationPath": "/sentinels" }
      ]
    },
    "hook:deploy:start:after": {
      "type": "command",
      "image": "default",
      "command": "set -eu; mkdir -p /sentinels; echo \"HOOK-AFTER-SENTINEL marker=${HOOK_MARKER:-unset}\"; printf '%s' \"${HOOK_MARKER:-unset}\" > /sentinels/after",
      "volumes": [
        { "name": "sentinels", "destinationPath": "/sentinels" }
      ]
    }
  }
}
